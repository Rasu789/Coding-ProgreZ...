class Solution:
    def myAtoi(self, s: str) -> int:
        s = s.lstrip() # Efficiently remove leading whitespace
        if not s:
            return 0
        
        sign = 1
        i = 0
        
        # Handle sign
        if s[0] == '-':
            sign = -1
            i = 1
        elif s[0] == '+':
            i = 1
            
        res = 0
        # Use slicing or a simple loop to build the number
        for j in range(i, len(s)):
            if not s[j].isdigit():
                break
            res = res * 10 + int(s[j])
            
            # Check bounds early to avoid unnecessary processing
            if sign * res >= 2**31 - 1: return 2**31 - 1
            if sign * res <= -2**31: return -2**31
            
        return sign * res
